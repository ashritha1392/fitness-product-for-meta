{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "jsx": "react-native",
    "declaration": false,
    "outDir": "dist",
    "rootDir": "."
  },
  "include": ["src", "App.tsx", "index.ts"],
  "exclude": ["node_modules", "dist", "native"]
}
